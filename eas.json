{
  "cli": {
    "version": ">= 18.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://mymealmatehelper.com",
        "EXPO_PUBLIC_AI_PIPELINE_URL": "https://mymealmatehelper.com/ai",
        "EXPO_PUBLIC_ANALYTICS_ENABLED": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://mymealmatehelper.com",
        "EXPO_PUBLIC_AI_PIPELINE_URL": "https://mymealmatehelper.com/ai",
        "EXPO_PUBLIC_ANALYTICS_ENABLED": "true"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://mymealmatehelper.com",
        "EXPO_PUBLIC_AI_PIPELINE_URL": "https://mymealmatehelper.com/ai",
        "EXPO_PUBLIC_ANALYTICS_ENABLED": "true"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
